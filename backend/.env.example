# Example Environment Variables
# Copy this file to .env.development or .env.production and update values

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=netgarde
DB_URL=postgresql+psycopg2://postgres:your_password_here@db:5432/netgarde

# Application Configuration
PYTHONUNBUFFERED=1
ENVIRONMENT=development

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=DEBUG

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# WireGuard enroll (used by POST /v1/enroll)
# These are also commonly set via docker-compose.yml `environment:` on EC2.
VPN_ENDPOINT=44.218.45.174:51820
VPN_SERVER_PUBLIC_KEY=REPLACE_WITH_wg0_PUBLIC_KEY

# Host WireGuard agent (EC2 systemd service; reachable from docker bridge)
WG_AGENT_URL=http://172.17.0.1:9109
WG_AGENT_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# DNS ingest: false = only blocked queries stored in RDS (default); true = legacy full log
PERSIST_ALL_DNS=false

# Anomaly detection
NEW_DOMAIN_ALERTS=true
BANDWIDTH_ALERT_MIB_PER_SEC=50

# Device identity (VPN clients receive device_token at enroll)
DEVICE_TOKEN_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
DEVICE_TOKEN_TTL_DAYS=365
# Optional: require Bearer on POST /v1/enroll (NetGardeClient --api-token / NETGARDE_API_TOKEN)
# ENROLL_BOOTSTRAP_TOKEN=REPLACE_WITH_ENROLL_BOOTSTRAP_SECRET

# Service identity: dns_log_watcher POST /dns-queries and /dns-queries/bulk
DNS_INGEST_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# Admin identity (dashboard + policy APIs)
ADMIN_API_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# Client behavior profiles (per-device baselines, alerts, optional auto-block)
BEHAVIOR_FAST_START=false
BEHAVIOR_BASELINE_LOOKBACK_DAYS=7
BEHAVIOR_MIN_PROFILE_DAYS=3
BEHAVIOR_MIN_PROFILE_QUERIES=500
BEHAVIOR_BASELINE_RECOMPUTE_HOURS=1
BEHAVIOR_SCORE_WINDOW_MINUTES=15
BEHAVIOR_ALERT_THRESHOLD=70
BEHAVIOR_AUTO_BLOCK_THRESHOLD=85
BEHAVIOR_AUTO_BLOCK_DEFAULT=false
BEHAVIOR_AUTO_BLOCK_TTL_HOURS=24
BEHAVIOR_MAX_BLOCKS_PER_DAY=10

