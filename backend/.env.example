# Example Environment Variables
# Copy this file to .env.development or .env.production and update values

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=netgarde
DB_URL=postgresql+psycopg2://postgres:your_password_here@db:5432/netgarde

# Application Configuration
PYTHONUNBUFFERED=1
ENVIRONMENT=development

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=DEBUG
LOG_JSON=0
LOG_SERVICE=backend

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# WireGuard enroll (used by POST /v1/enroll)
# These are also commonly set via docker-compose.yml `environment:` on EC2.
VPN_ENDPOINT=44.218.45.174:51820
VPN_SERVER_PUBLIC_KEY=REPLACE_WITH_wg0_PUBLIC_KEY

# Host WireGuard agent (EC2 systemd service; reachable from docker bridge)
WG_AGENT_URL=http://172.17.0.1:9109
WG_AGENT_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# DNS ingest: false = only blocked queries stored in RDS (default); true = legacy full log
PERSIST_ALL_DNS=false

# Anomaly detection
NEW_DOMAIN_ALERTS=true
BANDWIDTH_ALERT_MIB_PER_SEC=50
USAGE_LIVE_MAX_AGE_SEC=45

# Real-time VPN bandwidth (Redis rolling window + dashboard WebSocket)
REDIS_URL=redis://redis:6379/0
USAGE_REDIS_ENABLED=true
USAGE_HISTORY_MINUTES=60
# false = do not INSERT every sample into device_usage_samples (alerts still use Postgres)
USAGE_PERSIST_SAMPLES=false

# Device identity (VPN clients receive device_token at enroll)
DEVICE_TOKEN_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
DEVICE_TOKEN_TTL_DAYS=365
# Optional: require Bearer on POST /v1/enroll (NetGardeClient --api-token / NETGARDE_API_TOKEN)
# ENROLL_BOOTSTRAP_TOKEN=REPLACE_WITH_ENROLL_BOOTSTRAP_SECRET

# Service identity: dns_log_watcher POST /dns-queries and /dns-queries/bulk
DNS_INGEST_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# Admin identity (dashboard + policy APIs)
ADMIN_API_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# Client behavior profiles (per-device baselines, alerts, optional auto-block)
BEHAVIOR_FAST_START=false
BEHAVIOR_BASELINE_LOOKBACK_DAYS=7
BEHAVIOR_MIN_PROFILE_HOURS=0
BEHAVIOR_MIN_PROFILE_DAYS=3
BEHAVIOR_MIN_PROFILE_QUERIES=500
# Recompute stored baseline (median/P95) from rollups this often, including after profile_ready
BEHAVIOR_BASELINE_RECOMPUTE_HOURS=1
BEHAVIOR_SCORE_WINDOW_MINUTES=15
BEHAVIOR_ALERT_THRESHOLD=70
BEHAVIOR_AUTO_BLOCK_THRESHOLD=85
BEHAVIOR_AUTO_BLOCK_DEFAULT=true
BEHAVIOR_AUTO_BLOCK_TTL_HOURS=24
BEHAVIOR_AUTO_BLOCK_DOMAINS_PER_EVENT=5
BEHAVIOR_MAX_BLOCKS_PER_DAY=10
# Parent-facing behavior explanations: template | openai | ollama (scoring stays rules-based)
BEHAVIOR_REVIEW_MODE=template
BEHAVIOR_REVIEW_CACHE_TTL_SEC=300
DEVICE_COUNTRY_ALERT_ENABLED=true
DEVICE_COUNTRY_ALERT_COOLDOWN_HOURS=24

# Policy sync listener uses same channel as dns-sync report
POLICY_SYNC_REPORT_ENDPOINT=/policy/sync-report

# Policy packs: fetch upstream domain lists into on-disk snapshots (StevenBlack + UT1 games)
# Docker production sets POLICY_PACK_SNAPSHOT_DIR=/var/lib/netgarde/policy-snapshots (writable volume)
# POLICY_PACK_SNAPSHOT_DIR=
POLICY_PACK_FETCH_ENABLED=true
POLICY_PACK_REFRESH_ON_STARTUP=true
POLICY_PACK_SNAPSHOT_MAX_AGE_SECONDS=86400
POLICY_PACK_FETCH_TIMEOUT_SECONDS=30
# Optional overrides: adult=https://...,games=https://...
POLICY_PACK_REMOTE_URLS=

# Dashboard network review: template | openai | ollama
NETWORK_REVIEW_MODE=template
NETWORK_REVIEW_CACHE_TTL_SEC=90
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SEC=180

