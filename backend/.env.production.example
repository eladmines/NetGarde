# Production env template (do not rely on backend/.env.production on EC2 — CI used to overwrite it).
#
# On EC2 the live file is:
#   /etc/netgarde/backend.env
#
# First-time setup:
#   sudo mkdir -p /etc/netgarde
#   sudo cp backend/.env.production.example /etc/netgarde/backend.env
#   sudo chmod 600 /etc/netgarde/backend.env
#   sudo nano /etc/netgarde/backend.env
#
# Deploy merges DB_URL / WireGuard keys into /etc/netgarde/backend.env via scripts/ec2-sync-backend-env.sh

DB_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

LOG_TO_FILE=0
PYTHONUNBUFFERED=1

# WireGuard enroll
VPN_ENDPOINT=44.218.45.174:51820
VPN_SERVER_PUBLIC_KEY=REPLACE_WITH_wg0_PUBLIC_KEY

# Host WireGuard agent (must match systemd service token)
WG_AGENT_URL=http://172.17.0.1:9109
WG_AGENT_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# DNS ingest: false = only blocked queries stored in RDS (default); true = legacy full log
PERSIST_ALL_DNS=false

# Anomaly detection
NEW_DOMAIN_ALERTS=true
BANDWIDTH_ALERT_MIB_PER_SEC=50

DEVICE_TOKEN_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
DEVICE_TOKEN_TTL_DAYS=365
# ENROLL_BOOTSTRAP_TOKEN=REPLACE_WITH_ENROLL_BOOTSTRAP_SECRET

DNS_INGEST_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

ADMIN_API_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET
