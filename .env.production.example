# Root-level env for `docker compose` variable substitution.
# Copy to `.env` on the EC2 host (same directory as docker-compose.yml):
#   cp .env.production.example .env
#
# Docker Compose reads this file automatically for ${VAR} interpolation in docker-compose.yml.

# Host WireGuard agent (systemd service on EC2)
WG_AGENT_URL=http://172.17.0.1:9109
WG_AGENT_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Optional overrides (docker-compose.yml already has defaults)
# VPN_ENDPOINT=44.218.45.174:51820
# VPN_SERVER_PUBLIC_KEY=...
