# Copy to `.env` in this directory and fill in real values (never commit `.env`).
#   cp .env.example .env
#
# This file uses placeholders only — no account-specific hostnames or IDs.

# Shared
AWS_REGION=us-east-1

# Frontend static site (s3-setup.sh + update-github-actions-role.sh)
FRONTEND_S3_BUCKET=your-frontend-bucket-name

# Backend API CloudFront origin (cloudfront-backend-setup.sh)
BACKEND_EC2_IP=203.0.113.50
BACKEND_EC2_PUBLIC_DNS=ec2-203-0-113-50.compute-1.amazonaws.com
BACKEND_PORT=8000
BACKEND_CLOUDFRONT_COMMENT=NetGarde Backend API (example)

# GitHub Actions OIDC deploy role (update-github-actions-role.sh)
GITHUB_ACTIONS_ROLE_NAME=YourGitHubActionsDeployRole
GITHUB_ACTIONS_POLICY_NAME=YourGitHubActionsDeployPolicy
# Used for logging only; IAM policy uses wildcard for invalidation API
FRONTEND_CLOUDFRONT_DISTRIBUTION_ID=E1234567890ABC
