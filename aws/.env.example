# Shared
AWS_REGION=us-east-1

# Frontend static site (s3-setup.sh + update-github-actions-role.sh)
FRONTEND_S3_BUCKET=trustedge-frontend

# Backend container registry (ecr-setup.sh + deploy-backend.yml)
ECR_REPOSITORY=trustedge-backend

# Backend API CloudFront origin (cloudfront-backend-setup.sh)
BACKEND_EC2_IP=YOUR_EC2_PUBLIC_IP
BACKEND_EC2_PUBLIC_DNS=YOUR_EC2_PUBLIC_DNS_NAME
BACKEND_PORT=8000
BACKEND_CLOUDFRONT_COMMENT="TrustEdge Backend API"

# GitHub Actions OIDC deploy role (update-github-actions-role.sh)
# Use the role name from AWS_ROLE_ARN: arn:aws:iam::804012660077:role/ROLE_NAME
GITHUB_ACTIONS_ROLE_NAME=YourGitHubActionsDeployRole
GITHUB_ACTIONS_POLICY_NAME=YourGitHubActionsDeployPolicy
# Frontend CloudFront distribution (deploy-frontend.yml + cloudfront-frontend-update-origin.sh)
FRONTEND_CLOUDFRONT_DISTRIBUTION_ID=E26UGOT5YUPFRY

# Backend API HTTPS URL for frontend builds (deploy-frontend.yml BACKEND_API_URL)
BACKEND_API_CLOUDFRONT_URL=https://daemixzdg8jfd.cloudfront.net
