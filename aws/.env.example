# Copy to `.env` in this directory and adjust for your account (never commit `.env`).
#   cp .env.example .env

# Shared
AWS_REGION=us-east-1

# Frontend static site (s3-setup.sh + update-github-actions-role.sh)
FRONTEND_S3_BUCKET=netgarde-frontend

# Backend API CloudFront origin (cloudfront-backend-setup.sh)
BACKEND_EC2_IP=44.218.45.174
BACKEND_EC2_PUBLIC_DNS=ec2-44-218-45-174.compute-1.amazonaws.com
BACKEND_PORT=8000
BACKEND_CLOUDFRONT_COMMENT=NetGarde Backend API CDN

# GitHub Actions OIDC deploy role (update-github-actions-role.sh)
GITHUB_ACTIONS_ROLE_NAME=GitHubActionsDeployRole
GITHUB_ACTIONS_POLICY_NAME=GitHubActionsDeployPolicy
# Used for logging only; IAM policy uses wildcard for invalidation API
FRONTEND_CLOUDFRONT_DISTRIBUTION_ID=E26UGOT5YUPFRY
