# Example Environment Variables
# Copy this file to .env.development or .env.production and update values

# API Configuration
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_ENVIRONMENT=development

# Optional: send admin token for protected API endpoints
# REACT_APP_ADMIN_API_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET

# Source Maps
# true for development, false for production (security)
GENERATE_SOURCEMAP=true
