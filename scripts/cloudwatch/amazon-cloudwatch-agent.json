{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": []
      },
      "journald": {
        "collect_list": [
          {
            "unit": "netgarde-log-watcher.service",
            "log_group_name": "/netgarde/prod/log-watcher",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 14
          },
          {
            "unit": "netgarde-wg-agent.service",
            "log_group_name": "/netgarde/prod/wg-agent",
            "log_stream_name": "{instance_id}",
            "retention_in_days": 14
          }
        ]
      },
      "docker": {
        "collect_list": [
          {
            "docker_container": "netgarde-api",
            "log_group_name": "/netgarde/prod/backend",
            "log_stream_name": "{instance_id}/backend",
            "retention_in_days": 30
          },
          {
            "docker_container": "netgarde-dns-sync",
            "log_group_name": "/netgarde/prod/dns-sync",
            "log_stream_name": "{instance_id}/dns-sync",
            "retention_in_days": 14
          }
        ]
      }
    }
  }
}
